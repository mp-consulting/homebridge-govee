{
  "name": "@mp-consulting/homebridge-govee",
  "displayName": "Govee",
  "type": "module",
  "version": "1.0.8",
  "description": "Homebridge plugin to integrate Govee devices into HomeKit.",
  "author": "MP Consulting",
  "license": "MIT",
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mp-consulting/homebridge-govee.git"
  },
  "bugs": {
    "url": "https://github.com/mp-consulting/homebridge-govee/issues"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "homebridge-govee",
    "hoobs",
    "hoobs-plugin",
    "homekit",
    "siri",
    "govee"
  ],
  "main": "dist/index.js",
  "homebridge-ui": {
    "public": "homebridge-ui/public",
    "server": "homebridge-ui/server.js"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "watch": "npm run build && npm link && nodemon",
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && rimraf ./dist && tsc && cp -r src/connection/cert dist/connection/ && node scripts/generate-ui-models.js",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.1.2",
    "aws-iot-device-sdk": "^2.2.16",
    "axios": "^1.13.2",
    "fakegato-history": "^0.6.7",
    "node-persist": "^4.0.4",
    "p-queue": "^9.0.1"
  },
  "optionalDependencies": {
    "@stoprocent/bluetooth-hci-socket": "^2.2.3",
    "@stoprocent/noble": "^2.3.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/aws-iot-device-sdk": "^2.2.8",
    "@types/node": "^24.0.0",
    "@types/node-persist": "^3.1.8",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.19.0",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ]
}

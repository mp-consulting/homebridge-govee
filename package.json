{
  "name": "@mp-consulting/homebridge-govee",
  "displayName": "Govee",
  "type": "module",
  "version": "1.0.14",
  "description": "Homebridge plugin to integrate Govee devices into HomeKit.",
  "author": "MP Consulting",
  "license": "MIT",
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mp-consulting/homebridge-govee.git"
  },
  "bugs": {
    "url": "https://github.com/mp-consulting/homebridge-govee/issues"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "homebridge-govee",
    "hoobs",
    "hoobs-plugin",
    "homekit",
    "siri",
    "govee"
  ],
  "main": "dist/index.js",
  "homebridge-ui": {
    "public": "homebridge-ui/public",
    "server": "homebridge-ui/server.js"
  },
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "watch": "npm run build && npm link && nodemon",
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && rimraf ./dist && tsc && cp -r src/connection/cert dist/connection/ && node scripts/generate-ui-models.js",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "aws-iot-device-sdk": "^2.2.16",
    "axios": "^1.15.2",
    "fakegato-history": "^0.6.7",
    "node-forge": "^1.4.0",
    "node-persist": "^4.0.4",
    "p-queue": "^9.2.0"
  },
  "optionalDependencies": {
    "@stoprocent/bluetooth-hci-socket": "^2.2.6",
    "@stoprocent/noble": "^2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/aws-iot-device-sdk": "^2.2.9",
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/node-persist": "^3.1.8",
    "@vitest/coverage-v8": "^4.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint": "^10.2.1",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.22.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ]
}
